# ---- Servidor ----
PORT=3001
NODE_ENV=production

# ---- Postgres (Easypanel) ----
# Usa el HOST INTERNO del servicio de Postgres (no el público), ej:
#   postgres://sianna_app:TU_PASS@<servicio-pg>:5432/sianna
DATABASE_URL=

# ---- Auth admin ----
# Genera uno largo y aleatorio (p.ej. con: openssl rand -base64 48)
JWT_SECRET=
# COOKIE_SECURE=1 en producción (HTTPS). En local con http, ponlo en 0.
COOKIE_SECURE=1

# ---- CORS ----
# Orígenes permitidos separados por coma (p.ej. el dominio público de Vercel).
# En Easypanel el admin se sirve del mismo origen, normalmente no hace falta.
CORS_ORIGINS=http://localhost:5173

# ---- Subida de imágenes ----
# En Easypanel monta un VOLUMEN en esta ruta para que persistan los archivos.
UPLOAD_DIR=./uploads

# ---- Build del cliente ----
CLIENT_DIST=../client/dist
